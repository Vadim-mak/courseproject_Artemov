{
  "expo": {
    "name": "Tour Agency",
    "slug": "tour-agency-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E3B43"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ru.ncfu.touragency"
    },
    "android": {
      "package": "ru.ncfu.touragency",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#0E3B43"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}
